    <p class="before-price-note">※入会金別途</p>
    <button class="before-cta">今すぐ申し込む</button>
  </div>

  <div class="divider">↑ このLPの問題点を「改善分析」タブで確認 ↑</div>
  <div style="height:32px;"></div>
</div>

<!-- ============================================================
     AFTER TAB
============================================================ -->
<div class="after-section" id="tab-after">
  <div class="section-label">改善後 ／ AIコピーライティング適用版</div>

  <!-- After Hero -->
  <div class="after-hero">
    <div class="after-hero-inner">
      <div class="after-hero-left">
        <div class="after-eyebrow">
          <span class="after-eyebrow-line"></span>
          <span class="after-eyebrow-text">Online English Coaching</span>
